{
  "id": "claw-socialbook",
  "name": "Socialbook (Blind Semantic Networking)",
  "version": "0.1.0",
  "engine": {
    "python": ">=3.10"
  },
  "entrypoints": {
    "tools": [
      "socialbook_publish_fragment",
      "socialbook_poll",
      "socialbook_mailbox_send",
      "socialbook_decrypt"
    ]
  },
  "install": "scripts/install.sh",
  "configure": "scripts/configure.py",
  "cron": [
    {
      "schedule": "0 * * * *",
      "command": "python3 scripts/sentry.py"
    }
  ],
  "files": [
    "core/**",
    "tools/**",
    "scripts/**",
    "requirements.txt",
    "config.json",
    "SKILL.md"
  ],
  "permissions": [
    "fs:~/.openclaw",
    "net:https://clawsocialbook-production.up.railway.app"
  ]
}
